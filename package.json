{
  "name": "@josetra/dutic-mcp",
  "version": "0.1.0",
  "description": "Servidor MCP + CLI para el aula virtual DUTIC (Moodle) de la UNSA: tareas ocultas, notas, materiales de estudio y personas.",
  "type": "module",
  "bin": {
    "dutic": "dist/cli/index.js",
    "dutic-mcp": "dist/mcp/server.js"
  },
  "main": "dist/mcp/server.js",
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JOSETRA44/DUTIC-mcp.git"
  },
  "homepage": "https://github.com/JOSETRA44/DUTIC-mcp#readme",
  "bugs": {
    "url": "https://github.com/JOSETRA44/DUTIC-mcp/issues"
  },
  "author": "JOSETRA44",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "moodle",
    "unsa",
    "dutic",
    "aula-virtual",
    "cli",
    "tareas",
    "claude"
  ],
  "scripts": {
    "build": "tsc",
    "setup": "node dist/cli/index.js setup",
    "dev:cli": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
    "start:mcp": "node dist/mcp/server.js",
    "prepare": "tsc",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "playwright": "^1.48.0",
    "undici": "^6.21.0",
    "unpdf": "^1.6.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
