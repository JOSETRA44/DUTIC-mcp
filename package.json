{
  "name": "dutic-mcp",
  "version": "0.1.0",
  "description": "MCP server + CLI para el aula virtual DUTIC (Moodle) de la UNSA: tareas (incluidas las ocultas), cursos y recursos.",
  "type": "module",
  "bin": {
    "dutic": "dist/cli/index.js",
    "dutic-mcp": "dist/mcp/server.js"
  },
  "main": "dist/mcp/server.js",
  "scripts": {
    "build": "tsc",
    "setup": "npm run build && node scripts/install-skill.mjs && node scripts/setup-agents.mjs",
    "setup:agents": "node scripts/setup-agents.mjs",
    "setup:skill": "node scripts/install-skill.mjs",
    "dev:cli": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
    "start:mcp": "node dist/mcp/server.js",
    "prepare": "tsc",
    "postinstall": "node -e \"try{require('child_process').execSync('npx playwright install chromium',{stdio:'inherit'})}catch(e){console.error('playwright install skipped')}\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "playwright": "^1.48.0",
    "undici": "^6.21.0",
    "unpdf": "^1.6.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
